    \u0436\u0435 \u0445\u0440\u0430\u043D\u0438\u0442\u0435\u043B\u044C \u043F\u043E\u0434\u0437\u0435\u043C\u0435\u043B\u044C\u044F)
    \u0431\u044B\u043B \u0441\u043E\u0437\u0434\u0430\u043D \u0434\u043B\u044F \u043E\u0431\u043E\u0440\u043E\u043D\u044B
    \u043A\u043E\u043F\u0430\u0442\u0435\u043B\u0435\u0439. \u043E\u0431\u043B\u0430\u0434\u0430\u0435\u0442
    \u0440\u0430\u043A\u0435\u0442\u0430\u043C\u0438 \u0438 \u043C\u043E\u0449\u043D\u044B\u043C
    \u043B\u0430\u0437\u0435\u0440\u043E\u043C, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0430\u043A\u0442\u0438\u0432\u043D\u043E \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442
    \u0432 \u043D\u0430\u043F\u0430\u0434\u0435\u043D\u0438\u0438. \u0411\u043E\u043B\u044C\u0448\u043E\u0439
    \u0437\u0430\u043F\u0430\u0441 \u043F\u0440\u043E\u0447\u043D\u043E\u0441\u0442\u0438"
