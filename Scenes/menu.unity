      m_Calls: []
  m_text: "\u043E\u0434\u0438\u043D \u0438\u0437 \u043B\u044E\u0434\u0435\u0439,
    \u043F\u043E\u043F\u044B\u0442\u0430\u0432\u0448\u0438\u0445\u0441\u044F \u0441\u043F\u0430\u0441\u0442\u0438\u0441\u044C
    \u043E\u0442 \u0445\u043E\u043B\u043E\u0434\u0430 \u043F\u043E\u0434 \u0432\u043E\u0434\u043E\u0439.
    \u0427\u0442\u043E-\u0442\u043E \u044F\u0432\u043D\u043E \u0438\u0437\u043C\u0435\u043D\u0438\u043B\u043E
    \u0435\u0433\u043E : \u043E\u043D \u0431\u044B\u043B \u0436\u0438\u0432, \u0434\u0430\u0436\u0435
    \u043D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u0442\u043E \u0447\u0442\u043E
    \u0435\u0433\u043E \u043A\u043E\u0441\u0442\u044E\u043C \u0431\u044B\u043B \u0434\u043E
    \u043A\u0440\u0430\u0435\u0432 \u043D\u0430\u043F\u043E\u043B\u043D\u0435\u043C
    \u0432\u043E\u0434\u043E\u0439"
