    - target: {fileID: 1703085606805929456, guid: ef0b17875547c2c4eb788e421faf87fa, type: 3}
      propertyPath: lines.Array.data[0]
      value: "\u0422\u0443\u0442 \u043C\u043E\u0436\u0435\u0448\u044C \u0438 \u043D\u0435
        \u0441\u043F\u0440\u0430\u0448\u0438\u0432\u0430\u0442\u044C"
      objectReference: {fileID: 0}
    - target: {fileID: 1703085606805929456, guid: ef0b17875547c2c4eb788e421faf87fa, type: 3}
      propertyPath: lines.Array.data[1]
      value: "\u0442\u044B \u043C\u043E\u0436\u0435\u0448\u044C \u0441\u0434\u0435\u043B\u0430\u0442\u044C
        \u0440\u044B\u0432\u043E\u043A (\u0441\u0442\u0440\u0435\u043B\u043A\u0438
        - \u0437\u0430\u0434\u0430\u0442\u044C \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435
        \u0440\u044B\u0432\u043A\u0430, \u043B\u0435\u0432\u044B\u0439 Shift - \u0440\u044B\u0432\u043E\u043A)"
