      objectReference: {fileID: 21300000, guid: e62e1fe5b4774634282eec4bb99636e3, type: 3}
    - target: {fileID: 1703085606805929456, guid: ef0b17875547c2c4eb788e421faf87fa, type: 3}
      propertyPath: lines.Array.data[0]
      value: "\u0410 \u0432\u043E\u0442 \u0442\u0443\u0442 \u043D\u0430\u043C \u043F\u043E\u043D\u0430\u0434\u043E\u0431\u0438\u0442\u0441\u044F
        \u043D\u0430\u0448 \u0443\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u044B\u0439
        \u0442\u0440\u044E\u043A"
      objectReference: {fileID: 0}
    - target: {fileID: 1703085606805929456, guid: ef0b17875547c2c4eb788e421faf87fa, type: 3}
      propertyPath: lines.Array.data[1]
      value: "\u0442\u044B \u043C\u043E\u0436\u0435\u0448\u044C \u0432\u0441\u0435\u043B\u044F\u0442\u044C\u0441\u044F
        \u0438 \u0437\u0430\u0445\u0432\u0430\u0442\u044B\u0432\u0430\u0442\u044C
        \u043C\u0435\u0440\u0442\u0432\u044B\u0445 \u0432\u0440\u0430\u0433\u043E\u0432
        (A)"
      objectReference: {fileID: 0}
    - target: {fileID: 1703085606805929456, guid: ef0b17875547c2c4eb788e421faf87fa, type: 3}
      propertyPath: lines.Array.data[2]
      value: "\u0431\u043E\u043B\u044C\u0448\u0438\u043D\u0441\u0442\u0432\u043E
        \u0438\u0437 \u043D\u0438\u0445 \u043C\u043E\u0433\u0443 \u0430\u0442\u0430\u043A\u043E\u0432\u0430\u0442\u044C"
      objectReference: {fileID: 0}
    - target: {fileID: 1703085606805929456, guid: ef0b17875547c2c4eb788e421faf87fa, type: 3}
      propertyPath: lines.Array.data[3]
      value: "\u0422\u0430\u043A \u0447\u0442\u043E \u0432\u0441\u0435\u043B\u0438\u0441\u044C
        \u0432 \u043D\u0435\u0433\u043E \u0438 \u0440\u0430\u0437\u0431\u0435\u0439
        \u0434\u0435\u0440\u0435\u0432\u044F\u0448\u043A\u0443 (X)"
      objectReference: {fileID: 0}
    - target: {fileID: 1703085606805929456, guid: ef0b17875547c2c4eb788e421faf87fa, type: 3}
      propertyPath: lines.Array.data[4]
      value: "\u041A\u043E\u0433\u0434\u0430 \u0437\u0430\u043A\u043E\u043D\u0447\u0438\u0448\u044C,
        \u0432\u044B\u0441\u0435\u043B\u0438\u0441\u044C \u0438 \u0432\u0437\u043E\u0440\u0432\u0438
        \u0435\u0433\u043E (A)"
      objectReference: {fileID: 0}
    - target: {fileID: 1703085606805929456, guid: ef0b17875547c2c4eb788e421faf87fa, type: 3}
      propertyPath: lines.Array.data[5]
      value: "\u041D\u043E \u0441\u043B\u0443\u0447\u0430\u0439\u043D\u043E \u0432\u0440\u0435\u0437\u0430\u043B\u0441\u044F
        \u0432 \u043D\u0435\u0433\u043E"
      objectReference: {fileID: 0}
    - target: {fileID: 1703085606805929456, guid: ef0b17875547c2c4eb788e421faf87fa, type: 3}
      propertyPath: lines.Array.data[6]
      value: "\u0442\u0430\u043A \u0447\u0442\u043E \u0438\u0434\u0438 \u0434\u0430\u043B\u044C\u0448\u0435
        (\u0441\u0442\u0440\u0435\u043B\u043A\u0438 - \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0435,
        Z - \u043F\u0440\u044B\u0436\u043E\u043A)"
      objectReference: {fileID: 0}
    - target: {fileID: 1703085606805929456, guid: ef0b17875547c2c4eb788e421faf87fa, type: 3}
      propertyPath: lines.Array.data[7]
      value: "\u041F\u0440\u0438 \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0438
        (\u0441\u0442\u0440\u0435\u043B\u043A\u0430\u043C\u0438) \u0442\u044B \u043C\u043E\u0436\u0435\u0448\u044C
        \u0441\u0434\u0435\u043B\u0430\u0442\u044C \u0440\u044B\u0432\u043E\u043A"
      objectReference: {fileID: 0}
    - target: {fileID: 1703085606805929456, guid: ef0b17875547c2c4eb788e421faf87fa, type: 3}
      propertyPath: lines.Array.data[8]
      value: "\u0440\u044B\u0432\u043E\u043A \u043C\u043E\u0436\u043D\u043E \u0434\u0435\u043B\u0430\u0442\u044C
        \u0432 \u043B\u044E\u0431\u043E\u043C \u0438\u0437 8 \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0439"
      objectReference: {fileID: 0}
    - target: {fileID: 1703085606805929456, guid: ef0b17875547c2c4eb788e421faf87fa, type: 3}
      propertyPath: lines.Array.data[9]
      value: "\u041F\u043E\u043D\u044F\u043B"
      objectReference: {fileID: 0}
    - target: {fileID: 1703085606805929456, guid: ef0b17875547c2c4eb788e421faf87fa, type: 3}
      propertyPath: lines.Array.data[10]
      value: "\u0442\u043E\u0433\u0434\u0430 \u0432\u044B\u0431\u0438\u0440\u0430\u0439\u0441\u044F
        \u043E\u0442 \u0442\u0443\u0434\u0430"
      objectReference: {fileID: 0}
    - target: {fileID: 1703085606805929456, guid: ef0b17875547c2c4eb788e421faf87fa, type: 3}
      propertyPath: lines.Array.data[11]
      value: "\u0435\u0449\u0435 \u0441 \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u043C\u0438
        \u043F\u0440\u0435\u0434\u043C\u0435\u0442\u0430\u043C\u0438 \u043C\u043E\u0436\u043D\u043E
        \u0432\u0437\u0430\u0438\u043C\u043E\u0434\u0435\u0439\u0441\u0442\u0432\u043E\u0432\u0430\u0442\u044C
        (Z)"
      objectReference: {fileID: 0}
    - target: {fileID: 2309311096146495709, guid: ef0b17875547c2c4eb788e421faf87fa, type: 3}
      propertyPath: m_Name
